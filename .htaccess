# .htaccess
DirectoryIndex index.html

RewriteEngine On

# API маршруты (без блокировки)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api.php?path=$1 [QSA,L]

# Разрешаем прямой доступ к api.php
<Files "api.php">
    Require all granted
</Files>

# Блокируем только конфиги
<Files "config.php">
    Require all denied
</Files>

Options -Indexes